# ── Model ────────────────────────────────────────────────────────────────────
# Full pydantic-ai model string — change this to swap providers/models.
# Anthropic:
#   LLM_MODEL=anthropic:claude-sonnet-4-20250514
#   LLM_MODEL=anthropic:claude-opus-4-5
# Google Gemini:
#   LLM_MODEL=google-gla:gemini-2.5-flash-preview
#   LLM_MODEL=google-gla:gemini-1.5-pro
# OpenAI:
#   LLM_MODEL=openai:gpt-4o
LLM_MODEL=anthropic:claude-sonnet-4-20250514

# ── API Keys ─────────────────────────────────────────────────────────────────
# Set whichever key matches your chosen provider (others can be left blank).
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=

# ── Optional game tuning ─────────────────────────────────────────────────────
# TICK_RATE=2.0
# LLM_COMMAND_INTERVAL=10
# MAP_WIDTH=32
# MAP_HEIGHT=32
